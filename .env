# ─────────────────────────────────────────────────────────────────────────────
# Backpack & Fire Inventory System — environment variables
#
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────

# "sqlite" (default, local dev) or "postgres" (staging / production)
DB_DRIVER=sqlite

# SQLite:   file:./dev.db   (relative to project root)
# Postgres: postgres://user:password@localhost:5432/backpack_inventory
DATABASE_URL=file:./dev.db

# Set to "true" to log all SQL queries to stdout (dev only)
DB_LOG=false

# ── Local dev auth bypass ─────────────────────────────────────────────────────
#
# Set this to any string to skip OAuth entirely in local development.
# A supervisor user with this ID is auto-created in the DB on first request
# (requires `npm run db:seed` to have been run first).
# Remove or comment out this line before deploying to production.
#
DEV_AUTH_USER_ID=dev-user

# ── Auth.js (OIDC / OAuth) ────────────────────────────────────────────────────

# Required by Auth.js for signing session JWTs. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING

# Your OIDC provider's issuer URL.
# Examples:
#   Azure AD:  https://login.microsoftonline.com/<tenant-id>/v2.0
#   Okta:      https://your-org.okta.com/oauth2/default
#   Keycloak:  https://your-keycloak/realms/your-realm
OIDC_ISSUER=https://your-provider.example.com

# Client credentials from your OIDC provider's app registration
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# The URL Auth.js should redirect to after sign-in.
# In dev this is usually http://localhost:5173
AUTH_URL=http://localhost:5173

# ── File uploads (shipping receipts) ─────────────────────────────────────────

# "local" (dev) stores files under static/uploads/
# "s3" (prod) requires the AWS_* variables below
UPLOAD_DRIVER=local

# AWS S3 / compatible storage (required when UPLOAD_DRIVER=s3)
# AWS_REGION=ca-central-1
# AWS_BUCKET=backpack-inventory-receipts
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Application ───────────────────────────────────────────────────────────────

# Maximum file size for shipping receipt uploads (bytes). Default: 5 MB.
MAX_UPLOAD_BYTES=5242880

# Low-inventory warning threshold (units). Items at or below this level
# are highlighted in the dashboard.
LOW_INVENTORY_THRESHOLD=10

# ── Burn-rate forecast ────────────────────────────────────────────────────────

# Number of days of removal history used to calculate burn rate.
BURN_RATE_DAYS=30

# Days-remaining colour thresholds for the dashboard.
# > DAYS_GREEN            → green badge
# DAYS_YELLOW–DAYS_GREEN  → yellow badge
# < DAYS_YELLOW           → red badge
DAYS_GREEN=30
DAYS_YELLOW=14
